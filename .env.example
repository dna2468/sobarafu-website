# === 画像編集スクリプト用の設定 ===
# scripts/edit-menu-photos.py で使用する Gemini API キー
#
# 取得方法：
#   1. https://aistudio.google.com/apikey にアクセス
#   2. Google アカウントでログインして「Create API key」
#   3. 生成されたキーを下の GEMINI_API_KEY= のあとにペースト
#   4. このファイルを .env という名前でコピー（拡張子なし）
#
# 注意：
#   .env は .gitignore で除外されます（Git には絶対上がりません）
#   もし公開リポジトリ上で露出したら、直ちに AI Studio で該当キーを削除してください

GEMINI_API_KEY=your_api_key_here
